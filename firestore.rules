rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: true if current user has admin role in userRoles
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/userRoles/$(request.auth.token.email))
        && get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.role == 'admin';
    }
    // Helper: current user's division from userRoles (or empty = no restriction)
    function userDivision() {
      return request.auth != null
        && exists(/databases/$(database)/documents/userRoles/$(request.auth.token.email))
        ? get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.get('division', '')
        : '';
    }
    // User has division set in userRoles → must match report; no division → allow all (backwards compatible)
    function canAccessReport(divisionField) {
      return isAdmin()
        || userDivision() == ''
        || divisionField == userDivision();
    }

    match /kkpReports/{reportId} {
      allow read, update, delete: if request.auth != null && canAccessReport(resource.data.division);
      allow create: if request.auth != null && canAccessReport(request.resource.data.division);
    }
    match /userRoles/{email} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.email == email;
      // Any signed-in user may update their own doc to change username (Profil) etc., as long as role and
      // division stay the same—so typos can be fixed without an admin. Prevents self-promotion to admin or division changes.
      function selfMayEditOwnProfile() {
        return request.auth.token.email == email
          && request.resource.data.get('role', '') == resource.data.get('role', '')
          && request.resource.data.get('division', '') == resource.data.get('division', '');
      }
      // Admins can update/delete any user. Denied users can update their own doc to re-apply (role: denied -> pending).
      allow update: if request.auth != null && (
        isAdmin()
        || (request.auth.token.email == email && resource.data.role == 'denied')
        || selfMayEditOwnProfile()
      );
      allow delete: if request.auth != null && isAdmin();
    }
    match /divisionLookup/{division} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if request.auth != null;
    }
    match /auditLog/{logId} {
      allow read: if request.auth != null && isAdmin();
      allow create: if request.auth != null && isAdmin();
      allow update, delete: if false;
    }
    // Division dropdown options (admin-managed list). Anyone can read (for register/data); only admins write.
    match /config/divisions {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
  }
}
